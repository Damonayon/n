# ============================================================
# .env.example — шаблон переменных окружения для локальной разработки
# ============================================================
#
# Использование:
#   1. Скопируй файл:   cp .env.example .env
#   2. Заполни значения настоящими (см. комментарии ниже)
#   3. Файл .env уже в .gitignore — не попадёт в репозиторий
#
# В GitHub Actions эти же переменные приходят из Settings → Secrets / Variables,
# здесь файл нужен только для запуска скриптов на твоей машине.
# ============================================================


# ─── ОБЯЗАТЕЛЬНО ────────────────────────────────────────────

# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Твой Telegram user_id (получить в @userinfobot)
TELEGRAM_MODERATOR_ID=544843065

# ID или @username канала, куда публикуем
# Числовой ID для каналов выглядит как -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=@my_channel

# Personal Access Token GitHub с правом "Models: Read-only"
# https://github.com/settings/personal-access-tokens
GH_MODELS_TOKEN=github_pat_xxxxx


# ─── КОНФИГ КАНАЛА (опционально, есть дефолты) ──────────────

CHANNEL_TOPIC=Нейро-новости
CHANNEL_NICHE=искусственный интеллект и нейросети
CHANNEL_AUDIENCE=русскоязычные, 18-45 лет, интересуются технологиями и будущим
CHANNEL_LANG=русский

# Список RSS через запятую (без пробелов). Если пусто — дефолтный ИИ-набор.
# RSS_FEEDS=https://example.com/rss,https://other.com/feed


# ─── НАБЛЮДАЕМОСТЬ (опционально) ────────────────────────────

# DSN Sentry. Без него Sentry просто не включится — система работает.
# Получить: https://sentry.io → новый проект Python
# SENTRY_DSN=https://abc123@o12345.ingest.sentry.io/67890
SENTRY_DSN=

SENTRY_ENVIRONMENT=development

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO


# ─── ХРАНИЛИЩЕ (опционально) ────────────────────────────────

# По умолчанию — SQLite в data/bot.db. Менять не нужно для локальной разработки.
# DB_URL=sqlite:///data/bot.db
